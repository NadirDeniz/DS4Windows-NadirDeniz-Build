<Window x:Class="DS4WinWPF.DS4Forms.FirstLaunchUtilWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DS4WinWPF.DS4Forms"
        xmlns:lex="http://wpflocalizeextension.codeplex.com"
        lex:LocalizeDictionary.DesignCulture=""
        lex:ResxLocalizationProvider.DefaultAssembly="APP"
        lex:ResxLocalizationProvider.DefaultDictionary="Strings"
        mc:Ignorable="d"
        Title="{lex:Loc FirstLaunch.WinTitle}"
        Height="700"
        Width="720"
        MinHeight="620"
        MinWidth="640"
        WindowStartupLocation="CenterScreen"
        Style="{DynamicResource WindowStyle}">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Window.Resources>
    <DockPanel Margin="20,16,20,16" LastChildFill="True">
        <Button Content="{lex:Loc Close}"
                Click="Button_Click"
                DockPanel.Dock="Bottom"
                HorizontalAlignment="Right"
                MinWidth="120"
                MaxWidth="200"
                MinHeight="34"
                Padding="14,8"
                Margin="0,14,0,0" />

        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="0,0,4,0">
            <StackPanel Orientation="Vertical">
                <TextBlock Text="{lex:Loc FirstLaunch.Header}"
                           FontWeight="Bold"
                           FontSize="16"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,12"
                           TextWrapping="Wrap"
                           TextAlignment="Center" />

                <TextBlock TextWrapping="Wrap" Margin="8,0,8,16">
                    <TextBlock.Text>
                        <lex:Loc Key="FirstLaunch.DeviceIntroText" />
                    </TextBlock.Text>
                </TextBlock>

                <TextBlock Text="{lex:Loc FirstLaunch.InputDevicesSection}"
                           FontWeight="SemiBold"
                           FontSize="13"
                           Margin="4,0,4,10" />

                <Border Background="{DynamicResource ModernSurfaceBrush}"
                        BorderBrush="{DynamicResource ModernBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="14,12"
                        Margin="0,0,0,12">
                    <StackPanel Orientation="Vertical">
                        <CheckBox Name="ds4SupportEnableCkb"
                                  IsChecked="{Binding EnableDS4}"
                                  Content="{lex:Loc ControllerSupportDS4}"
                                  FontWeight="Bold" />
                        <TextBlock Text="{lex:Loc FirstLaunch.DS4EnableText}"
                                   Margin="0,8,0,0"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Background="{DynamicResource ModernSurfaceBrush}"
                        BorderBrush="{DynamicResource ModernBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="14,12"
                        Margin="0,0,0,12">
                    <StackPanel Orientation="Vertical">
                        <CheckBox Name="dualSenseSupportEnableCkb"
                                  IsChecked="{Binding EnableDualSense}"
                                  Content="{lex:Loc ControllerSupportDualSense}"
                                  FontWeight="Bold" />
                        <TextBlock Text="{lex:Loc FirstLaunch.DSEnableText}"
                                   Margin="0,8,0,0"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Background="{DynamicResource ModernSurfaceBrush}"
                        BorderBrush="{DynamicResource ModernBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="14,12"
                        Margin="0,0,0,12">
                    <StackPanel Orientation="Vertical">
                        <CheckBox Name="switchProSupportEnableCkb"
                                  IsChecked="{Binding EnableSwitchPro}"
                                  Content="{lex:Loc ControllerSupportSwitchPro}"
                                  FontWeight="Bold" />
                        <TextBlock Text="{lex:Loc FirstLaunch.SwitchProEnableText}"
                                   Margin="0,8,0,0"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Background="{DynamicResource ModernSurfaceBrush}"
                        BorderBrush="{DynamicResource ModernBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="14,12"
                        Margin="0,0,0,12">
                    <StackPanel Orientation="Vertical">
                        <CheckBox Name="joyConSupportEnableCkb"
                                  IsChecked="{Binding EnableJoyCon}"
                                  Content="{lex:Loc ControllerSupportJoyCon}"
                                  FontWeight="Bold" />
                        <TextBlock Text="{lex:Loc FirstLaunch.JoyConEnableText}"
                                   Margin="0,8,0,0"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Background="{DynamicResource ModernSurfaceBrush}"
                        BorderBrush="{DynamicResource ModernBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="14,12"
                        Margin="0,0,0,16">
                    <StackPanel Orientation="Vertical">
                        <CheckBox Name="ds3SupportEnableCkb"
                                  IsChecked="{Binding EnableDS3}"
                                  Content="{lex:Loc ControllerSupportDS3}"
                                  FontWeight="Bold" />
                        <TextBlock Text="{lex:Loc FirstLaunch.DS3EnableText}"
                                   Margin="0,8,0,0"
                                   TextWrapping="Wrap" />
                        <TextBlock Margin="0,8,0,0" TextWrapping="Wrap">
                            <Hyperlink x:Name="dsHidMiniLink"
                                       Click="DsHidMiniLink_Click"
                                       Foreground="{DynamicResource ModernAccentBrush}">https://vigem.org/projects/DsHidMini/</Hyperlink>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <TextBlock Text="{lex:Loc FirstLaunch.VirtualDevicesSection}"
                           FontWeight="SemiBold"
                           FontSize="13"
                           Margin="4,0,4,10" />

                <Border Background="{DynamicResource ModernSurfaceBrush}"
                        BorderBrush="{DynamicResource ModernBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="14,12"
                        Margin="0,0,0,12">
                    <StackPanel Orientation="Vertical">
                        <CheckBox IsChecked="{Binding EnableMoonlight}"
                                  Content="{lex:Loc ControllerSupportMoonlight}"
                                  FontWeight="Bold" />
                        <TextBlock Text="{lex:Loc FirstLaunch.MoonlightEnableText}"
                                   Margin="0,8,0,0"
                                   TextWrapping="Wrap" />
                        <CheckBox IsChecked="{Binding EnableAdvancedMoonlight}"
                                  Content="{lex:Loc AdvancedSupport}"
                                  Margin="20,10,0,0"
                                  Visibility="{Binding EnableMoonlight, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    </StackPanel>
                </Border>

                <TextBlock Text="{lex:Loc FirstLaunch.OtherOptionsSection}"
                           FontWeight="SemiBold"
                           FontSize="13"
                           Margin="4,0,4,10" />

                <Border Background="{DynamicResource ModernSurfaceBrush}"
                        BorderBrush="{DynamicResource ModernBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="14,12"
                        Margin="0,0,0,8">
                    <StackPanel Orientation="Vertical">
                        <CheckBox IsChecked="{Binding VerboseLogMessages}"
                                  Content="{lex:Loc EnableVerboseLog}"
                                  ToolTip="{lex:Loc EnableVerboseLogTip}"
                                  FontWeight="Bold" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
