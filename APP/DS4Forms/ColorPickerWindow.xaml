<Window x:Class="DS4WinWPF.DS4Forms.ColorPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
        xmlns:lex="http://wpflocalizeextension.codeplex.com"
        lex:LocalizeDictionary.DesignCulture=""
        lex:ResxLocalizationProvider.DefaultAssembly="APP"
        lex:ResxLocalizationProvider.DefaultDictionary="Strings"
        xmlns:local="clr-namespace:DS4WinWPF.DS4Forms"
        mc:Ignorable="d"
        Title="{lex:Loc RecordBox.ChangeLightbarColor}"
        MinHeight="360"
        MinWidth="300"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Style="{DynamicResource WindowStyle}">
    <Border Background="{DynamicResource BackgroundColor}"
            Padding="{StaticResource ModernPagePadding}"
            ClipToBounds="False">
        <Border Background="{DynamicResource ModernSurfaceBrush}"
                BorderBrush="{DynamicResource ModernBorderBrush}"
                BorderThickness="1"
                CornerRadius="{StaticResource ModernCardRadius}"
                Padding="{StaticResource ModernCardPadding}"
                ClipToBounds="True"
                SnapsToDevicePixels="True">
            <xctk:ColorCanvas x:Name="colorPicker"
                                SelectedColorChanged="ColorPicker_SelectedColorChanged"
                                Background="Transparent"
                                Foreground="{DynamicResource ModernTextBrush}"
                                BorderBrush="{DynamicResource ModernBorderBrush}"
                                UsingAlphaChannel="False"
                                MinWidth="260"
                                MinHeight="300" />
        </Border>
    </Border>
</Window>
