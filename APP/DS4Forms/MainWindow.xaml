<Window x:Name="mainDS4Window" x:Class="DS4WinWPF.DS4Forms.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:tb="http://www.hardcodet.net/taskbar"
        xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
        xmlns:lex="http://wpflocalizeextension.codeplex.com"
        lex:LocalizeDictionary.DesignCulture=""
        lex:ResxLocalizationProvider.DefaultAssembly="APP"
        lex:ResxLocalizationProvider.DefaultDictionary="Strings"
        xmlns:local="clr-namespace:DS4WinWPF.DS4Forms"
        xmlns:localConverters="clr-namespace:DS4WinWPF.DS4Forms.Converters"
        xmlns:system="clr-namespace:System;assembly=mscorlib"
        xml:lang="en-US"
        mc:Ignorable="d"
        Title="APP" Height="500" Width="800" Closing="MainDS4Window_Closing" Closed="MainDS4Window_Closed" StateChanged="MainDS4Window_StateChanged" SizeChanged="MainDS4Window_SizeChanged" LocationChanged="MainDS4Window_LocationChanged" MinWidth="600" MinHeight="250"
        Style="{DynamicResource WindowStyle}">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <local:ImageLocationPaths x:Key="ImgLocPaths" />
    </Window.Resources>
    <DockPanel>
        <tb:TaskbarIcon x:Name="notifyIcon" IconSource="{Binding IconSource,Mode=OneWay}" ToolTipText="{Binding TooltipText,Mode=OneWay}" MenuActivation="RightClick" TrayRightMouseUp="NotifyIcon_TrayRightMouseUp" TrayMiddleMouseDown="NotifyIcon_TrayMiddleMouseDown" TrayMouseDoubleClick="NotifyIcon_TrayMouseDoubleClick">
            <!--<tb:TaskbarIcon.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Open" />
                    <Separator />
                    <MenuItem x:Name="exitMenuItem" Header="Exit" />
                </ContextMenu>
            </tb:TaskbarIcon.ContextMenu>-->
        </tb:TaskbarIcon>

        <Border DockPanel.Dock="Bottom"
                Padding="14,8,14,10"
                ClipToBounds="False"
                Background="{DynamicResource ModernSurfaceAltBrush}"
                BorderBrush="{DynamicResource ModernBorderBrush}"
                BorderThickness="0,1,0,0">
            <Grid MinHeight="{StaticResource ModernBottomActionBarMinHeight}"
                  ClipToBounds="False">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Status bar branding (visual only; does not change behavior) -->
                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Left">
                    <Ellipse Width="8"
                             Height="8"
                             Margin="2,0,9,0"
                             VerticalAlignment="Center"
                             Fill="{DynamicResource ModernAccentBrush}" />
                    <TextBlock Text="Ryochan7's DS4Windows - NadirDeniz Build ( Version 4.0 )"
                               VerticalAlignment="Center"
                               FontSize="12"
                               Foreground="{DynamicResource ModernTextMutedBrush}" />
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            ClipToBounds="False">
                    <Button x:Name="StartStopBtn"
                            Content="{lex:Loc StartText}"
                            Margin="12,0,0,0"
                            MinWidth="72"
                            Padding="14,6"
                            VerticalAlignment="Center"
                            Click="StartStopBtn_Click"
                            Foreground="{DynamicResource ForegroundColor}" />
                </StackPanel>
            </Grid>
        </Border>
        <TabControl x:Name="mainTabCon" DockPanel.Dock="Top" ClipToBounds="False" FocusVisualStyle="{x:Null}">
            <TabItem Header="{lex:Loc Controllers}" IsEnabled="{Binding FullTabsEnabled,Mode=OneWay}">
                <Grid Margin="6,4,6,6" ClipToBounds="False">
                    <Label x:Name="noContLb" Visibility="Hidden" Content="{lex:Loc NoControllersConnected}" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" />
                    <ListView x:Name="controllerLV"
                              ItemsSource="{Binding ControllerCol}"
                              SelectionMode="Single"
                              SelectedIndex="{Binding CurrentIndex, Mode=OneWayToSource}"
                              Margin="0"
                              ClipToBounds="False"
                              PreviewMouseDown="ControllerLV_PreviewMouseDown">
                        <ListView.View>
                            <GridView>
                                <GridView.ColumnHeaderContainerStyle>
                                    <Style TargetType="{x:Type GridViewColumnHeader}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Setter Property="Height" Value="0" />
                                    </Style>
                                </GridView.ColumnHeaderContainerStyle>
                                <GridViewColumn x:Name="idColumn" Header="" Width="180">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock x:Name="idColumnTxtB" Text="{Binding DeviceTypeText, Mode=OneWay}" ToolTip="{Binding TooltipIDText, Mode=OneWay}" ToolTipOpening="IdColumnTxtB_ToolTipOpening" Tag="{Binding DevIndex, Mode=OneTime}"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn x:Name="selectProfileColumn" Header="" Width="148">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <!-- Do not set Width=column here: Width+Margin overflowed and clipped the ComboBox right border. -->
                                            <Grid Margin="2,0,4,0"
                                                  VerticalAlignment="Center"
                                                  ClipToBounds="False"
                                                  SnapsToDevicePixels="True">
                                                <ComboBox x:Name="selectProfCombo"
                                                          Style="{StaticResource ModernGridComboBoxStyle}"
                                                          HorizontalAlignment="Stretch"
                                                          ItemsSource="{Binding ProfileListCol}"
                                                          SelectedIndex="{Binding SelectedIndex}"
                                                          Tag="{Binding DevIndex, Mode=OneTime}"
                                                          Visibility="{Binding PrimaryDevice, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                          SelectionChanged="SelectProfCombo_SelectionChanged"
                                                          KeyDown="SelectProfCombo_KeyDown">
                                                    <ComboBox.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding Name,Mode=OneWay,FallbackValue=''}" />
                                                        </DataTemplate>
                                                    </ComboBox.ItemTemplate>
                                                </ComboBox>
                                            </Grid>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn x:Name="editColumn" Width="100">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Width="{Binding ElementName=editColumn, Path=Width}">
                                                <xctk:SplitButton x:Name="ProfEditSBtn" Content="{lex:Loc Edit}" MinWidth="60" MinHeight="26" Visibility="{Binding PrimaryDevice, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                                  Tag="{Binding DevIndex, Mode=OneTime}" Click="ProfEditSBtn_Click" HorizontalAlignment="Center">
                                                    <xctk:SplitButton.DropDownContent>
                                                        <Button x:Name="newProfBtn" Content="{lex:Loc NewProfile}" MinWidth="120" Tag="{Binding DevIndex, Mode=OneTime}" Click="NewProfBtn_Click"  />
                                                    </xctk:SplitButton.DropDownContent>
                                                </xctk:SplitButton>
                                            </StackPanel>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn x:Name="customColorColumn" Width="150">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Width="{Binding ElementName=customColorColumn, Path=Width}">
                                                <!--<xctk:ColorPicker x:Name="customColorPick" SelectedColor="{Binding LightColor, Mode=OneWay}" Width="150"
                                                                  ShowTabHeaders="False" ColorMode="ColorCanvas" SelectedColorChanged="CustomColorPick_SelectedColorChanged" />-->
                                                <Button x:Name="LightColorBtn"
                                                        Width="120"
                                                        MinHeight="26"
                                                        Background="{Binding LightColor, Mode=OneWay}"
                                                        BorderBrush="{DynamicResource ModernBorderBrush}"
                                                        BorderThickness="1"
                                                        Tag="{Binding DevIndex, Mode=OneTime}"
                                                        Click="LightColorBtn_Click">
                                                    <!--<Button.ContextMenu>
                                                        <ContextMenu>
                                                            <MenuItem Header="Use Profile Color" IsCheckable="True" />
                                                            <MenuItem Header="Use Custom Color" IsCheckable="True" />
                                                        </ContextMenu>
                                                    </Button.ContextMenu>-->
                                                </Button>
                                            </StackPanel>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Grid>
            </TabItem>

            <TabItem x:Name="profilesTab" Header="{lex:Loc Profiles}">
                <DockPanel x:Name="profDockPanel">
                    <Border x:Name="profOptsToolbar"
                            DockPanel.Dock="Top"
                            Background="{DynamicResource ModernSurfaceAltBrush}"
                            BorderBrush="{DynamicResource ModernBorderBrush}"
                            BorderThickness="0,0,0,1"
                            Padding="12,10,12,10"
                            ClipToBounds="False">
                        <WrapPanel Orientation="Horizontal">
                            <Button x:Name="newProfListBtn" Style="{StaticResource ModernToolbarNewStyle}" Click="NewProfListBtn_Click">
                                <StackPanel Orientation="Horizontal">
                                    <Viewbox Width="{StaticResource ModernToolbarIconSize}" Height="{StaticResource ModernToolbarIconSize}" Margin="0,0,10,0">
                                        <Path Data="{StaticResource ToolbarIconNewGeo}" Style="{StaticResource ModernToolbarIconPathStyle}" Stroke="{StaticResource ToolbarAccentNewBrush}" />
                                    </Viewbox>
                                    <TextBlock Text="{lex:Loc New}" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button x:Name="editProfBtn" Style="{StaticResource ModernToolbarEditStyle}" IsEnabled="False" Click="EditProfBtn_Click">
                                <StackPanel Orientation="Horizontal">
                                    <Viewbox Width="{StaticResource ModernToolbarIconSize}" Height="{StaticResource ModernToolbarIconSize}" Margin="0,0,10,0">
                                        <Path Data="{StaticResource ToolbarIconEditGeo}" Fill="{StaticResource ToolbarAccentEditBrush}" Stretch="Uniform" SnapsToDevicePixels="True" />
                                    </Viewbox>
                                    <TextBlock Text="{lex:Loc Edit}" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button x:Name="deleteProfBtn" Style="{StaticResource ModernToolbarDeleteStyle}" IsEnabled="False" Click="DeleteProfBtn_Click">
                                <StackPanel Orientation="Horizontal">
                                    <Viewbox Width="{StaticResource ModernToolbarIconSize}" Height="{StaticResource ModernToolbarIconSize}" Margin="0,0,10,0">
                                        <Path Data="{StaticResource ToolbarIconDeleteGeo}" Style="{StaticResource ModernToolbarIconPathStyle}" Stroke="{StaticResource ToolbarAccentDeleteBrush}" />
                                    </Viewbox>
                                    <TextBlock Text="{lex:Loc Delete}" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button x:Name="renameProfBtn" Style="{StaticResource ModernToolbarRenameStyle}" IsEnabled="False" Click="RenameProfBtn_Click">
                                <StackPanel Orientation="Horizontal">
                                    <Viewbox Width="{StaticResource ModernToolbarIconSize}" Height="{StaticResource ModernToolbarIconSize}" Margin="0,0,10,0">
                                        <Path Data="{StaticResource ToolbarIconRenameGeo}" Fill="{StaticResource ToolbarAccentRenameBrush}" Stretch="Uniform" SnapsToDevicePixels="True" />
                                    </Viewbox>
                                    <TextBlock Text="{lex:Loc RenameProfile}" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button x:Name="dupProfBtn" Style="{StaticResource ModernToolbarDuplicateStyle}" IsEnabled="False" Click="DupProfBtn_Click">
                                <StackPanel Orientation="Horizontal">
                                    <Viewbox Width="{StaticResource ModernToolbarIconSize}" Height="{StaticResource ModernToolbarIconSize}" Margin="0,0,10,0">
                                        <Path Data="{StaticResource ToolbarIconDuplicateGeo}" Style="{StaticResource ModernToolbarIconPathStyle}" Stroke="{StaticResource ToolbarAccentDuplicateBrush}" />
                                    </Viewbox>
                                    <TextBlock Text="{lex:Loc Duplicate}" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button x:Name="importProfBtn" Style="{StaticResource ModernToolbarImportStyle}" Click="ImportProfBtn_Click">
                                <StackPanel Orientation="Horizontal">
                                    <Viewbox Width="{StaticResource ModernToolbarIconSize}" Height="{StaticResource ModernToolbarIconSize}" Margin="0,0,10,0">
                                        <Path Data="{StaticResource ToolbarIconImportGeo}" Style="{StaticResource ModernToolbarIconPathStyle}" Stroke="{StaticResource ToolbarAccentImportBrush}" />
                                    </Viewbox>
                                    <TextBlock Text="{lex:Loc Import}" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button x:Name="exportProfBtn" Style="{StaticResource ModernToolbarExportStyle}" IsEnabled="False" Click="ExportProfBtn_Click">
                                <StackPanel Orientation="Horizontal">
                                    <Viewbox Width="{StaticResource ModernToolbarIconSize}" Height="{StaticResource ModernToolbarIconSize}" Margin="0,0,10,0">
                                        <Path Data="{StaticResource ToolbarIconExportGeo}" Style="{StaticResource ModernToolbarIconPathStyle}" Stroke="{StaticResource ToolbarAccentExportBrush}" />
                                    </Viewbox>
                                    <TextBlock Text="{lex:Loc Export}" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </WrapPanel>
                    </Border>
                    <Border x:Name="dupBoxBar" DockPanel.Dock="Top" HorizontalAlignment="Center" Visibility="Collapsed"
                            Background="{DynamicResource ModernSurfaceAltBrush}" Padding="8,10" MinHeight="{StaticResource ModernBottomActionBarMinHeight}" ClipToBounds="False">
                        <local:DupBox x:Name="dupBox" />
                    </Border>

                    <ListBox x:Name="profilesListBox"
                             DockPanel.Dock="Bottom"
                             ItemContainerStyle="{StaticResource ModernProfileListItemStyle}"
                             BorderThickness="0"
                             Background="Transparent"
                             Padding="8,6,8,8"
                             SelectionChanged="ProfilesListBox_SelectionChanged"
                             MouseDoubleClick="ProfilesListBox_MouseDoubleClick"
                             PreviewMouseDown="ProfilesListBox_PreviewMouseDown">
                        <ListBox.Resources>
                            <localConverters:EscapeAccessKeysConverter x:Key="escapeAccessConvert" />
                        </ListBox.Resources>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name, Mode=OneWay, Converter={StaticResource escapeAccessConvert}}"
                                           FontSize="13"
                                           VerticalAlignment="Center" />
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </TabItem>
            <!-- Geri getirmek için Visibility="Collapsed" satırını kaldır (veya Visible yap). -->
            <TabItem Header="{lex:Loc AutoProfiles}" Visibility="Collapsed" IsEnabled="{Binding FullTabsEnabled,Mode=OneWay}">
                <local:AutoProfiles x:Name="autoProfControl">

                </local:AutoProfiles>
            </TabItem>
            <!-- Geri getirmek için Visibility="Collapsed" satırını kaldır (veya Visible yap). -->
            <TabItem Header="{lex:Loc OutputSlots}" Visibility="Collapsed" IsEnabled="{Binding FullTabsEnabled,Mode=OneWay}">
                <local:OutputSlotManagerControl x:Name="slotManControl">

                </local:OutputSlotManagerControl>
            </TabItem>
            <TabItem x:Name="settingsTab" Header="{lex:Loc Settings}" IsEnabled="{Binding ViewEnabled,Mode=OneWay}">
                <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto" Background="{DynamicResource BackgroundColor}">
                    <StackPanel Margin="16,20,16,16" MinWidth="280">
                        <!-- Gizlendi: istenildiğinde geri açılabilir
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Label Content="{lex:Loc IconChoice}" ContentStringFormat="{}{0}:" VerticalAlignment="Center" />
                            <ComboBox x:Name="useIconChoiceCom" SelectedIndex="{Binding IconChoiceIndex,FallbackValue='0'}" Margin="12,0,0,0" MinWidth="140">
                                <ComboBoxItem Content="{lex:Loc Default}"/>
                                <ComboBoxItem Content="{lex:Loc Colored}"/>
                                <ComboBoxItem Content="{lex:Loc White}"/>
                                <ComboBoxItem Content="{lex:Loc Black}"/>
                                <ComboBoxItem Content="{lex:Loc Battery}"/>
                            </ComboBox>
                        </StackPanel>
                        -->
                        
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                            <Label Content="{lex:Loc AppTheme}" ContentStringFormat="{}{0}:" VerticalAlignment="Center" />
                            <ComboBox x:Name="appThemeCom" SelectedIndex="{Binding AppChoiceIndex,FallbackValue='2'}" Margin="12,0,0,0" MinWidth="140">
                                <ComboBoxItem Content="{lex:Loc Default}" Visibility="Collapsed"/>
                                <ComboBoxItem Content="{lex:Loc Light}"/>
                                <ComboBoxItem Content="{lex:Loc Dark}"/>
                            </ComboBox>
                        </StackPanel>
                        <Button x:Name="deviceOptionSettingsBtn" MaxWidth="160" HorizontalAlignment="Left" Content="{lex:Loc DeviceOptions}" Click="DeviceOptionSettingsBtn_Click" />
                    </StackPanel>
                </ScrollViewer>

            </TabItem>

        </TabControl>
    </DockPanel>
</Window>
