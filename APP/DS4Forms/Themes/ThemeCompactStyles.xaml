<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit">

    <!-- Host panel for custom curve row (TextBox + editor button) -->
    <Style x:Key="ModernCurveRowPanel" TargetType="{x:Type DockPanel}">
        <Setter Property="ClipToBounds" Value="False" />
        <Setter Property="MinHeight" Value="32" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Margin" Value="0,2,0,2" />
    </Style>

    <!-- Compact inline controls for tight grid rows -->
    <Style x:Key="ModernInlineButtonStyle" TargetType="{x:Type Button}">
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Foreground" Value="{DynamicResource ModernTextBrush}" />
        <Setter Property="Background" Value="{DynamicResource ModernInputBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ModernBorderBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="6,4" />
        <Setter Property="Margin" Value="{StaticResource ModernInlineMargin}" />
        <Setter Property="MinWidth" Value="28" />
        <Setter Property="MinHeight" Value="{StaticResource ModernInlineMinHeight}" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="UseLayoutRounding" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Grid Margin="1" ClipToBounds="False" SnapsToDevicePixels="True" UseLayoutRounding="True">
                        <Border x:Name="Bd"
                                CornerRadius="{StaticResource ModernInlineRadius}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                SnapsToDevicePixels="True"
                                ClipToBounds="False"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}"
                                              RecognizesAccessKey="True" />
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ModernInputHoverBrush}" />
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource ModernBorderHoverBrush}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ModernInputPressedBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="{DynamicResource ModernDisabledTextBrush}" />
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ModernInputDisabledBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ModernInlineTextBoxStyle" TargetType="{x:Type TextBox}">
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Foreground" Value="{DynamicResource ModernTextBrush}" />
        <Setter Property="Background" Value="{DynamicResource ModernInputBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ModernBorderBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="6,4" />
        <Setter Property="Margin" Value="{StaticResource ModernInlineMargin}" />
        <Setter Property="CaretBrush" Value="{DynamicResource ModernTextBrush}" />
        <Setter Property="MinHeight" Value="{StaticResource ModernInlineMinHeight}" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="UseLayoutRounding" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type TextBox}">
                    <Grid Margin="1" ClipToBounds="False" SnapsToDevicePixels="True" UseLayoutRounding="True">
                        <Border x:Name="Bd"
                                CornerRadius="{StaticResource ModernInlineRadius}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                SnapsToDevicePixels="True"
                                ClipToBounds="False">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center" />
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource ModernBorderHoverBrush}" />
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource ModernAccentBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="{DynamicResource ModernDisabledTextBrush}" />
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ModernInputDisabledBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- xctk numeric inputs: rounded outer border, no double-chrome clipping -->
    <Style TargetType="{x:Type xctk:IntegerUpDown}">
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Foreground" Value="{DynamicResource ModernTextBrush}" />
        <Setter Property="Background" Value="{DynamicResource ModernInputBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ModernBorderBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="4,3" />
        <Setter Property="Margin" Value="{StaticResource ModernInlineMargin}" />
        <Setter Property="MinHeight" Value="{StaticResource ModernInlineMinHeight}" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="UseLayoutRounding" Value="True" />
        <Setter Property="HorizontalContentAlignment" Value="Right" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type xctk:IntegerUpDown}">
                    <Grid Margin="1" ClipToBounds="False" SnapsToDevicePixels="True" UseLayoutRounding="True">
                        <Border x:Name="Bd"
                                CornerRadius="{StaticResource ModernInlineRadius}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                SnapsToDevicePixels="True"
                                ClipToBounds="False">
                            <xctk:ButtonSpinner x:Name="PART_Spinner"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                AllowSpin="{TemplateBinding AllowSpin}"
                                                ButtonSpinnerLocation="{TemplateBinding ButtonSpinnerLocation}"
                                                ShowButtonSpinner="{TemplateBinding ShowButtonSpinner}"
                                                HorizontalContentAlignment="Stretch"
                                                VerticalContentAlignment="Stretch">
                                <xctk:WatermarkTextBox x:Name="PART_TextBox"
                                                       Background="Transparent"
                                                       BorderThickness="0"
                                                       Foreground="{TemplateBinding Foreground}"
                                                       Padding="{TemplateBinding Padding}"
                                                       HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                       VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                                                       TextAlignment="{TemplateBinding TextAlignment}"
                                                       Watermark="{TemplateBinding Watermark}" />
                            </xctk:ButtonSpinner>
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource ModernBorderHoverBrush}" />
                        </Trigger>
                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource ModernAccentBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="{DynamicResource ModernDisabledTextBrush}" />
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ModernInputDisabledBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type xctk:DoubleUpDown}">
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Foreground" Value="{DynamicResource ModernTextBrush}" />
        <Setter Property="Background" Value="{DynamicResource ModernInputBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ModernBorderBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="4,3" />
        <Setter Property="Margin" Value="{StaticResource ModernInlineMargin}" />
        <Setter Property="MinHeight" Value="{StaticResource ModernInlineMinHeight}" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="UseLayoutRounding" Value="True" />
        <Setter Property="HorizontalContentAlignment" Value="Right" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type xctk:DoubleUpDown}">
                    <Grid Margin="1" ClipToBounds="False" SnapsToDevicePixels="True" UseLayoutRounding="True">
                        <Border x:Name="Bd"
                                CornerRadius="{StaticResource ModernInlineRadius}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                SnapsToDevicePixels="True"
                                ClipToBounds="False">
                            <xctk:ButtonSpinner x:Name="PART_Spinner"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                AllowSpin="{TemplateBinding AllowSpin}"
                                                ButtonSpinnerLocation="{TemplateBinding ButtonSpinnerLocation}"
                                                ShowButtonSpinner="{TemplateBinding ShowButtonSpinner}"
                                                HorizontalContentAlignment="Stretch"
                                                VerticalContentAlignment="Stretch">
                                <xctk:WatermarkTextBox x:Name="PART_TextBox"
                                                       Background="Transparent"
                                                       BorderThickness="0"
                                                       Foreground="{TemplateBinding Foreground}"
                                                       Padding="{TemplateBinding Padding}"
                                                       HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                       VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                                                       TextAlignment="{TemplateBinding TextAlignment}"
                                                       Watermark="{TemplateBinding Watermark}" />
                            </xctk:ButtonSpinner>
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource ModernBorderHoverBrush}" />
                        </Trigger>
                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource ModernAccentBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="{DynamicResource ModernDisabledTextBrush}" />
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ModernInputDisabledBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
