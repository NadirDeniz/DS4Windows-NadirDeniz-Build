<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="ThemeSpacing.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <!-- Subtle toolbar accent colors (work on light and dark surfaces) -->
    <SolidColorBrush x:Key="ToolbarAccentNewBrush" Color="#FF4A90D9" />
    <SolidColorBrush x:Key="ToolbarAccentEditBrush" Color="#FFE6A817" />
    <SolidColorBrush x:Key="ToolbarAccentDeleteBrush" Color="#FFE05252" />
    <SolidColorBrush x:Key="ToolbarAccentRenameBrush" Color="#FF9B59D9" />
    <SolidColorBrush x:Key="ToolbarAccentDuplicateBrush" Color="#FF2EC4C4" />
    <SolidColorBrush x:Key="ToolbarAccentImportBrush" Color="#FF3DB87A" />
    <SolidColorBrush x:Key="ToolbarAccentExportBrush" Color="#FFE98A3A" />

    <!-- Outline-style toolbar icons (16x16 viewbox, stroke-friendly) -->
    <Geometry x:Key="ToolbarIconNewGeo">M8,3.5 L8,12.5 M3.5,8 L12.5,8</Geometry>
    <Geometry x:Key="ToolbarIconEditGeo">M11.3,3.6 L13.4,5.7 L5.6,13.5 L2.9,14.3 L3.7,11.6 Z</Geometry>
    <Geometry x:Key="ToolbarIconDeleteGeo">M4,6.2 H12 M5.2,6.2 L5.7,4.5 H10.3 L10.8,6.2 M5.5,6.2 V13.5 H10.5 V6.2 M7.1,8.3 V11.5 M9.9,8.3 V11.5</Geometry>
    <Geometry x:Key="ToolbarIconRenameGeo">M4,12.5 H12 M9.6,5.2 L12.1,7.7 L6.2,13.6 L3.5,14.3 L4.2,11.6 Z</Geometry>
    <Geometry x:Key="ToolbarIconDuplicateGeo">M5.5,4.5 H11.5 V11.5 H5.5 Z M8.5,6.5 H14.5 V13.5 H8.5 Z</Geometry>
    <Geometry x:Key="ToolbarIconImportGeo">M8,3.5 V9.8 M5.4,7.2 L8,4.6 L10.6,7.2 M4.5,12.5 H11.5 V14 H4.5 Z</Geometry>
    <Geometry x:Key="ToolbarIconExportGeo">M8,6.2 V12.5 M10.6,9.8 L8,12.4 L5.4,9.8 M4.5,12.5 H11.5 V14 H4.5 Z</Geometry>

    <Style x:Key="ModernToolbarIconPathStyle" TargetType="{x:Type Path}">
        <Setter Property="Stretch" Value="Uniform" />
        <Setter Property="Fill" Value="Transparent" />
        <Setter Property="StrokeThickness" Value="1.35" />
        <Setter Property="StrokeLineJoin" Value="Round" />
        <Setter Property="StrokeStartLineCap" Value="Round" />
        <Setter Property="StrokeEndLineCap" Value="Round" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
    </Style>

    <Style x:Key="ModernToolbarButtonBase" TargetType="{x:Type Button}">
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Foreground" Value="{DynamicResource ModernTextBrush}" />
        <Setter Property="Background" Value="{DynamicResource ModernInputBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ModernBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="{StaticResource ModernToolbarPadding}" />
        <Setter Property="MinHeight" Value="34" />
        <Setter Property="Margin" Value="0,0,8,0" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="UseLayoutRounding" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Grid SnapsToDevicePixels="True" ClipToBounds="False">
                        <Border x:Name="Bd"
                                SnapsToDevicePixels="True"
                                CornerRadius="{StaticResource ModernToolbarRadius}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                ClipToBounds="False" />
                        <!-- Hover/press fill: opacity animated for a soft ~130ms transition -->
                        <Border x:Name="HoverOverlay"
                                SnapsToDevicePixels="True"
                                Margin="{TemplateBinding BorderThickness}"
                                CornerRadius="{StaticResource ModernToolbarRadius}"
                                Background="{DynamicResource ModernInputHoverBrush}"
                                Opacity="0" />
                        <ContentPresenter Margin="{TemplateBinding Padding}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          TextElement.Foreground="{TemplateBinding Foreground}"
                                          RecognizesAccessKey="True" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HoverOverlay"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="1" Duration="0:0:0.13" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HoverOverlay"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0" Duration="0:0:0.13" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="HoverOverlay" Property="Background" Value="{DynamicResource ModernInputPressedBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ModernToolbarNewStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource ModernToolbarButtonBase}">
        <Setter Property="BorderBrush" Value="{StaticResource ToolbarAccentNewBrush}" />
    </Style>
    <Style x:Key="ModernToolbarEditStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource ModernToolbarButtonBase}">
        <Setter Property="BorderBrush" Value="{StaticResource ToolbarAccentEditBrush}" />
    </Style>
    <Style x:Key="ModernToolbarDeleteStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource ModernToolbarButtonBase}">
        <Setter Property="BorderBrush" Value="{StaticResource ToolbarAccentDeleteBrush}" />
    </Style>
    <Style x:Key="ModernToolbarRenameStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource ModernToolbarButtonBase}">
        <Setter Property="BorderBrush" Value="{StaticResource ToolbarAccentRenameBrush}" />
    </Style>
    <Style x:Key="ModernToolbarDuplicateStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource ModernToolbarButtonBase}">
        <Setter Property="BorderBrush" Value="{StaticResource ToolbarAccentDuplicateBrush}" />
    </Style>
    <Style x:Key="ModernToolbarImportStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource ModernToolbarButtonBase}">
        <Setter Property="BorderBrush" Value="{StaticResource ToolbarAccentImportBrush}" />
    </Style>
    <Style x:Key="ModernToolbarExportStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource ModernToolbarButtonBase}">
        <Setter Property="BorderBrush" Value="{StaticResource ToolbarAccentExportBrush}" />
    </Style>

</ResourceDictionary>
