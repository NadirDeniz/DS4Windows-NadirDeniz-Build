<Window x:Class="DS4WinWPF.DS4Forms.SaveWhere"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:lex="http://wpflocalizeextension.codeplex.com"
        xmlns:local="clr-namespace:DS4WinWPF.DS4Forms"
        lex:LocalizeDictionary.DesignCulture=""
        lex:ResxLocalizationProvider.DefaultAssembly="APP"
        lex:ResxLocalizationProvider.DefaultDictionary="Strings"
        mc:Ignorable="d"
        Title="{lex:Loc SaveWhere.WinTitle}"
        Width="520"
        MinWidth="500"
        MinHeight="300"
        SizeToContent="Height"
        MaxHeight="420"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Style="{DynamicResource WindowStyle}">
    <Border Padding="16,14,16,18">
        <StackPanel>
            <DockPanel x:Name="multipleSavesDockP" Margin="0,0,0,8">
                <Label Content="{lex:Loc SaveWhere.MultipleSaves}" VerticalAlignment="Center" />
                <CheckBox x:Name="dontDeleteCk"
                          Content="{lex:Loc SaveWhere.DontDelete}"
                          DockPanel.Dock="Right"
                          HorizontalAlignment="Right"
                          VerticalAlignment="Center" />
            </DockPanel>
            <TextBlock x:Name="pickWhereTxt"
                       Text="{lex:Loc SaveWhere.PickWhere}"
                       TextWrapping="Wrap"
                       HorizontalAlignment="Center"
                       Margin="4,4,4,12"
                       TextAlignment="Center" />
            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel x:Name="progFolderPanel" Grid.Column="0">
                    <Button x:Name="progFolderBtn"
                            Content="{lex:Loc ProgramFolder}"
                            MinHeight="32"
                            Padding="12,8"
                            Margin="0,0,0,10"
                            Click="ProgFolderBtn_Click" />
                    <TextBlock TextWrapping="Wrap"
                               TextAlignment="Center"
                               Margin="4,0,4,4"
                               Text="{lex:Loc SaveWhere.ProgramFolderDescText}" />
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <Button x:Name="appdataBtn"
                            Content="{lex:Loc Appdata}"
                            MinHeight="32"
                            Padding="12,8"
                            Margin="0,0,0,10"
                            Click="AppdataBtn_Click" />
                    <TextBlock TextWrapping="Wrap"
                               TextAlignment="Center"
                               Margin="4,0,4,4"
                               Text="{lex:Loc SaveWhere.AppDataDescText}" />
                </StackPanel>
            </Grid>
        </StackPanel>
    </Border>
</Window>
