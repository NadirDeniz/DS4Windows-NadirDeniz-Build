<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="ThemeSpacing.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <!-- Brushes are defined per theme (DefaultTheme / DarkTheme). Styles use DynamicResource. -->

    <!-- ComboBox dropdown toggle: invisible hit-target only (arrow drawn once in ComboBox template). -->
    <Style x:Key="ModernComboBoxToggle" TargetType="{x:Type ToggleButton}">
        <Setter Property="Focusable" Value="False" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ToggleButton}">
                    <Border Background="Transparent" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ComboBox inside tight GridView cells: no outer margin (prevents right-edge clip). -->
    <Style x:Key="ModernGridComboBoxStyle" TargetType="{x:Type ComboBox}" BasedOn="{StaticResource {x:Type ComboBox}}">
        <Setter Property="Margin" Value="0" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="MinHeight" Value="28" />
    </Style>

    <!-- Label -->
    <Style TargetType="{x:Type Label}">
        <Setter Property="Foreground" Value="{DynamicResource ModernTextBrush}" />
        <Style.Triggers>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Foreground" Value="{DynamicResource ModernDisabledTextBrush}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- TextBlock -->
    <Style TargetType="{x:Type TextBlock}">
        <Setter Property="Foreground" Value="{DynamicResource ModernTextBrush}" />
        <Style.Triggers>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Foreground" Value="{DynamicResource ModernDisabledTextBrush}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Button -->
    <Style TargetType="{x:Type Button}">
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Foreground" Value="{DynamicResource ModernTextBrush}" />
        <Setter Property="Background" Value="{DynamicResource ModernInputBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ModernBorderBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="{StaticResource ModernButtonPadding}" />
        <Setter Property="Margin" Value="{StaticResource ModernControlMargin}" />
        <Setter Property="MinHeight" Value="26" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="UseLayoutRounding" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Grid Margin="1"
                          SnapsToDevicePixels="True"
                          UseLayoutRounding="True"
                          ClipToBounds="False">
                        <Border x:Name="Bd"
                                SnapsToDevicePixels="True"
                                CornerRadius="{StaticResource ModernControlRadius}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              TextElement.Foreground="{TemplateBinding Foreground}"
                                              RecognizesAccessKey="True" />
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ModernInputHoverBrush}" />
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource ModernBorderHoverBrush}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ModernInputPressedBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="{DynamicResource ModernDisabledTextBrush}" />
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ModernInputDisabledBrush}" />
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource ModernBorderBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- TextBox -->
    <Style TargetType="{x:Type TextBox}">
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Foreground" Value="{DynamicResource ModernTextBrush}" />
        <Setter Property="Background" Value="{DynamicResource ModernInputBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ModernBorderBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="{StaticResource ModernTextBoxPadding}" />
        <Setter Property="Margin" Value="{StaticResource ModernControlMargin}" />
        <Setter Property="CaretBrush" Value="{DynamicResource ModernTextBrush}" />
        <Setter Property="MinHeight" Value="26" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="UseLayoutRounding" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type TextBox}">
                    <Grid Margin="1"
                          SnapsToDevicePixels="True"
                          UseLayoutRounding="True"
                          ClipToBounds="False">
                        <Border x:Name="Bd"
                                SnapsToDevicePixels="True"
                                CornerRadius="{StaticResource ModernControlRadius}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                ClipToBounds="False">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          SnapsToDevicePixels="True" />
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource ModernBorderHoverBrush}" />
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource ModernAccentBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="{DynamicResource ModernDisabledTextBrush}" />
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ModernInputDisabledBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ComboBox -->
    <Style TargetType="{x:Type ComboBox}">
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Foreground" Value="{DynamicResource ModernTextBrush}" />
        <Setter Property="Background" Value="{DynamicResource ModernInputBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ModernBorderBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="{StaticResource ModernComboBoxPadding}" />
        <Setter Property="Margin" Value="{StaticResource ModernControlMargin}" />
        <Setter Property="MinHeight" Value="26" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="UseLayoutRounding" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ComboBox}">
                    <Grid SnapsToDevicePixels="True"
                          UseLayoutRounding="True"
                          ClipToBounds="False">
                        <Border x:Name="Bd"
                                SnapsToDevicePixels="True"
                                CornerRadius="{StaticResource ModernControlRadius}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                ClipToBounds="True"
                                Padding="1,0,1,0">
                            <Grid ClipToBounds="True">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="26" />
                                </Grid.ColumnDefinitions>
                                <ContentPresenter x:Name="ContentSite"
                                                  Grid.Column="0"
                                                  Margin="8,5,4,5"
                                                  HorizontalAlignment="Stretch"
                                                  VerticalAlignment="Center"
                                                  IsHitTestVisible="False"
                                                  TextElement.Foreground="{TemplateBinding Foreground}"
                                                  Content="{TemplateBinding SelectionBoxItem}"
                                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                  ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}" />
                                <Path Grid.Column="1"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      Width="8"
                                      Height="5"
                                      Data="M 0 0 L 4 4 L 8 0 Z"
                                      Fill="{DynamicResource ModernTextMutedBrush}"
                                      IsHitTestVisible="False"
                                      SnapsToDevicePixels="True" />
                                <ToggleButton x:Name="ToggleButton"
                                              Grid.Column="0"
                                              Grid.ColumnSpan="2"
                                              Style="{StaticResource ModernComboBoxToggle}"
                                              Focusable="False"
                                              ClickMode="Press"
                                              IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}" />
                            </Grid>
                        </Border>
                        <Popup x:Name="PART_Popup"
                               AllowsTransparency="True"
                               Placement="Bottom"
                               IsOpen="{TemplateBinding IsDropDownOpen}"
                               PopupAnimation="Fade"
                               Focusable="False">
                            <Border MinWidth="{TemplateBinding ActualWidth}"
                                    MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                    Margin="0,4,0,0"
                                    Padding="4"
                                    Background="{DynamicResource ModernSurfaceAltBrush}"
                                    BorderBrush="{DynamicResource ModernBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="{StaticResource ModernControlRadius}"
                                    SnapsToDevicePixels="True"
                                    ClipToBounds="False">
                                <Border.Effect>
                                    <DropShadowEffect Color="#FF000000"
                                                      BlurRadius="16"
                                                      ShadowDepth="2"
                                                      Opacity="0.42" />
                                </Border.Effect>
                                <ScrollViewer SnapsToDevicePixels="True"
                                              HorizontalScrollBarVisibility="Disabled"
                                              Padding="0">
                                    <StackPanel IsItemsHost="True"
                                                KeyboardNavigation.DirectionalNavigation="Contained" />
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource ModernBorderHoverBrush}" />
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ModernInputHoverBrush}" />
                        </Trigger>
                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource ModernAccentBrush}" />
                        </Trigger>
                        <Trigger Property="IsDropDownOpen" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource ModernAccentBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="{DynamicResource ModernDisabledTextBrush}" />
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ModernInputDisabledBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type ComboBoxItem}">
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Foreground" Value="{DynamicResource ModernTextBrush}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="UseLayoutRounding" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ComboBoxItem}">
                    <Border x:Name="ItemBd"
                            Margin="2,1"
                            Padding="10,7"
                            CornerRadius="{StaticResource ModernSmallRadius}"
                            Background="Transparent"
                            SnapsToDevicePixels="True"
                            ClipToBounds="False">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="Center"
                                          TextElement.Foreground="{TemplateBinding Foreground}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="ItemBd" Property="Background" Value="{DynamicResource ModernInputHoverBrush}" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="ItemBd" Property="Background" Value="{DynamicResource ModernSelectionBrush}" />
                            <Setter Property="FontWeight" Value="SemiBold" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="{DynamicResource ModernDisabledTextBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- CheckBox: visible box + check in all states (not only on hover) -->
    <Style TargetType="{x:Type CheckBox}">
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Foreground" Value="{DynamicResource ModernTextBrush}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="{DynamicResource ModernBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="{StaticResource ModernCheckBoxLabelPadding}" />
        <Setter Property="Margin" Value="{StaticResource ModernControlMargin}" />
        <Setter Property="MinHeight" Value="22" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="UseLayoutRounding" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type CheckBox}">
                    <Grid Background="Transparent"
                          SnapsToDevicePixels="True"
                          UseLayoutRounding="True"
                          ClipToBounds="False">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border x:Name="Box"
                                Width="{StaticResource ModernCheckBoxSize}"
                                Height="{StaticResource ModernCheckBoxSize}"
                                CornerRadius="{StaticResource ModernCheckBoxRadius}"
                                Background="{DynamicResource ModernInputBrush}"
                                BorderBrush="{DynamicResource ModernBorderBrush}"
                                BorderThickness="1"
                                VerticalAlignment="Center"
                                SnapsToDevicePixels="True">
                            <Grid>
                                <Path x:Name="CheckMark"
                                      Data="M 3.2,9.2 L 7.2,13.2 L 14.8,5.6"
                                      Stroke="{DynamicResource ModernOnAccentTextBrush}"
                                      StrokeThickness="2"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round"
                                      Visibility="Collapsed"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      SnapsToDevicePixels="True" />
                                <Rectangle x:Name="IndeterminateMark"
                                           Width="10"
                                           Height="10"
                                           RadiusX="1.5"
                                           RadiusY="1.5"
                                           Fill="{DynamicResource ModernOnAccentTextBrush}"
                                           Visibility="Collapsed"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Grid>
                        </Border>
                        <ContentPresenter Grid.Column="1"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          RecognizesAccessKey="True"
                                          SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Box" Property="Background" Value="{DynamicResource ModernAccentBrush}" />
                            <Setter TargetName="Box" Property="BorderBrush" Value="{DynamicResource ModernAccentBrush}" />
                            <Setter TargetName="CheckMark" Property="Visibility" Value="Visible" />
                            <Setter TargetName="IndeterminateMark" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="{x:Null}">
                            <Setter TargetName="Box" Property="Background" Value="{DynamicResource ModernAccentBrush}" />
                            <Setter TargetName="Box" Property="BorderBrush" Value="{DynamicResource ModernAccentBrush}" />
                            <Setter TargetName="CheckMark" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="IndeterminateMark" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsChecked" Value="False" />
                                <Condition Property="IsMouseOver" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Box" Property="Background" Value="{DynamicResource ModernInputHoverBrush}" />
                            <Setter TargetName="Box" Property="BorderBrush" Value="{DynamicResource ModernBorderHoverBrush}" />
                        </MultiTrigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsChecked" Value="True" />
                                <Condition Property="IsMouseOver" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Box" Property="Background" Value="{DynamicResource ModernAccentHoverBrush}" />
                            <Setter TargetName="Box" Property="BorderBrush" Value="{DynamicResource ModernAccentHoverBrush}" />
                        </MultiTrigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsChecked" Value="{x:Null}" />
                                <Condition Property="IsMouseOver" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Box" Property="Background" Value="{DynamicResource ModernAccentHoverBrush}" />
                            <Setter TargetName="Box" Property="BorderBrush" Value="{DynamicResource ModernAccentHoverBrush}" />
                        </MultiTrigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="{DynamicResource ModernDisabledTextBrush}" />
                            <Setter TargetName="Box" Property="Background" Value="{DynamicResource ModernInputDisabledBrush}" />
                            <Setter TargetName="Box" Property="BorderBrush" Value="{DynamicResource ModernBorderBrush}" />
                            <Setter TargetName="Box" Property="Opacity" Value="0.55" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- RadioButton -->
    <Style TargetType="{x:Type RadioButton}">
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Foreground" Value="{DynamicResource ModernTextBrush}" />
        <Setter Property="Margin" Value="{StaticResource ModernControlMargin}" />
        <Style.Triggers>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Foreground" Value="{DynamicResource ModernDisabledTextBrush}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ListBox -->
    <Style TargetType="{x:Type ListBox}">
        <Setter Property="Foreground" Value="{DynamicResource ModernTextBrush}" />
        <Setter Property="Background" Value="{DynamicResource ModernSurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ModernBorderBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Margin" Value="{StaticResource ModernControlMargin}" />
        <Setter Property="Padding" Value="{StaticResource ModernSurfacePadding}" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="UseLayoutRounding" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ListBox}">
                    <Border Margin="1"
                            SnapsToDevicePixels="True"
                            CornerRadius="{StaticResource ModernSmallRadius}"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="1"
                            ClipToBounds="False">
                        <ScrollViewer Focusable="False" Padding="{TemplateBinding Padding}">
                            <ItemsPresenter SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                        </ScrollViewer>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type ListBoxItem}">
        <Setter Property="Foreground" Value="{DynamicResource ModernTextBrush}" />
        <Setter Property="Padding" Value="6,3" />
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{DynamicResource ModernInputHoverBrush}" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Foreground" Value="{DynamicResource ModernDisabledTextBrush}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Profile list rows: accent bar + soft selection glow (Profiles tab). -->
    <Style x:Key="ModernProfileListItemStyle" TargetType="{x:Type ListBoxItem}">
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Foreground" Value="{DynamicResource ModernTextBrush}" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Margin" Value="2,3" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="UseLayoutRounding" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ListBoxItem}">
                    <Grid Margin="1,0,2,0"
                          SnapsToDevicePixels="True"
                          UseLayoutRounding="True"
                          ClipToBounds="False">
                        <Border x:Name="SelGlow"
                                Margin="-2"
                                CornerRadius="{StaticResource ModernControlRadius}"
                                Background="Transparent"
                                Opacity="0"
                                SnapsToDevicePixels="True">
                            <Border.Effect>
                                <DropShadowEffect Color="{DynamicResource ModernAccentGlowColor}"
                                                  BlurRadius="16"
                                                  ShadowDepth="0"
                                                  Opacity="0.55" />
                            </Border.Effect>
                        </Border>
                        <Border x:Name="Bd"
                                CornerRadius="{StaticResource ModernControlRadius}"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                Padding="10,8"
                                SnapsToDevicePixels="True">
                            <Grid>
                                <Border x:Name="AccentBar"
                                        Width="3"
                                        HorizontalAlignment="Left"
                                        Margin="0,3,0,3"
                                        CornerRadius="2"
                                        Background="{DynamicResource ModernAccentBrush}"
                                        Opacity="0" />
                                <ContentPresenter Margin="10,0,4,0"
                                                  VerticalAlignment="Center"
                                                  TextElement.Foreground="{TemplateBinding Foreground}" />
                            </Grid>
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ModernInputHoverBrush}" />
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource ModernBorderBrush}" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ModernSelectionBrush}" />
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource ModernBorderHoverBrush}" />
                            <Setter TargetName="AccentBar" Property="Opacity" Value="1" />
                            <Setter TargetName="SelGlow" Property="Opacity" Value="0.22" />
                            <Setter Property="FontWeight" Value="SemiBold" />
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsSelected" Value="True" />
                                <Condition Property="Selector.IsSelectionActive" Value="False" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ModernSelectionInactiveBrush}" />
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource ModernBorderBrush}" />
                            <Setter TargetName="SelGlow" Property="Opacity" Value="0.1" />
                            <Setter Property="FontWeight" Value="Normal" />
                        </MultiTrigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsSelected" Value="True" />
                                <Condition Property="IsMouseOver" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="SelGlow" Property="Opacity" Value="0.32" />
                        </MultiTrigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="{DynamicResource ModernDisabledTextBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Footer text action (Hotkeys / About). -->
    <Style x:Key="ModernFooterLinkButtonStyle" TargetType="{x:Type Button}">
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Padding" Value="10,6" />
        <Setter Property="Margin" Value="0" />
        <Setter Property="Foreground" Value="{DynamicResource ModernTextMutedBrush}" />
        <Setter Property="FontSize" Value="12.5" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Grid ClipToBounds="False" SnapsToDevicePixels="True">
                        <Border x:Name="LinkGlow"
                                Margin="-2"
                                CornerRadius="{StaticResource ModernSmallRadius}"
                                Background="Transparent"
                                Opacity="0"
                                SnapsToDevicePixels="True">
                            <Border.Effect>
                                <DropShadowEffect Color="{DynamicResource ModernAccentGlowColor}"
                                                  BlurRadius="14"
                                                  ShadowDepth="0"
                                                  Opacity="0.85" />
                            </Border.Effect>
                        </Border>
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="{StaticResource ModernSmallRadius}"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True"
                                ClipToBounds="False">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ModernTabInactiveHoverBrush}" />
                            <Setter Property="Foreground" Value="{DynamicResource ModernAccentHoverBrush}" />
                            <Setter TargetName="LinkGlow" Property="Opacity" Value="0.42" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ModernInputPressedBrush}" />
                            <Setter TargetName="LinkGlow" Property="Opacity" Value="0.24" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="{DynamicResource ModernDisabledTextBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ListView / GridView: borderless headers, card-style rows (Controllers, Output Slots, …). -->
    <Style TargetType="{x:Type ListView}">
        <Setter Property="Foreground" Value="{DynamicResource ModernTextBrush}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="{x:Null}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Margin" Value="{StaticResource ModernControlMargin}" />
        <Setter Property="Padding" Value="4,2,4,4" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="UseLayoutRounding" Value="True" />
        <Setter Property="ClipToBounds" Value="False" />
    </Style>

    <Style TargetType="{x:Type GridViewColumnHeader}">
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource ModernTextMutedBrush}" />
        <Setter Property="BorderBrush" Value="{x:Null}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="10,10,10,8" />
        <Setter Property="FontSize" Value="11.5" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="UseLayoutRounding" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type GridViewColumnHeader}">
                    <Grid SnapsToDevicePixels="True"
                          UseLayoutRounding="True"
                          ClipToBounds="False">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0"
                                Background="Transparent"
                                BorderThickness="0"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              TextElement.Foreground="{TemplateBinding Foreground}"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <!-- Invisible resize handle (no column divider lines). -->
                        <Thumb x:Name="PART_HeaderGripper"
                               Grid.Column="1"
                               Width="8"
                               Background="Transparent"
                               BorderBrush="Transparent"
                               BorderThickness="0"
                               Cursor="SizeWE"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Stretch"
                               Focusable="False"
                               OverridesDefaultStyle="True">
                            <Thumb.Template>
                                <ControlTemplate TargetType="{x:Type Thumb}">
                                    <Border Background="Transparent" SnapsToDevicePixels="True" />
                                </ControlTemplate>
                            </Thumb.Template>
                        </Thumb>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="Role" Value="Padding">
                <Setter Property="Width" Value="0" />
                <Setter Property="MinWidth" Value="0" />
                <Setter Property="MaxWidth" Value="0" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type GridViewColumnHeader}">
                            <Border Width="0" Background="Transparent" />
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Foreground" Value="{DynamicResource ModernTextBrush}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="{x:Type ListViewItem}">
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Foreground" Value="{DynamicResource ModernTextBrush}" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Margin" Value="3,4" />
        <Setter Property="MinHeight" Value="46" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="UseLayoutRounding" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ListViewItem}">
                    <Grid Margin="1,0,2,0"
                          SnapsToDevicePixels="True"
                          UseLayoutRounding="True"
                          ClipToBounds="False">
                        <Border x:Name="SelGlow"
                                Margin="-2"
                                CornerRadius="{StaticResource ModernControlRadius}"
                                Background="Transparent"
                                Opacity="0"
                                SnapsToDevicePixels="True">
                            <Border.Effect>
                                <DropShadowEffect Color="{DynamicResource ModernAccentGlowColor}"
                                                  BlurRadius="14"
                                                  ShadowDepth="0"
                                                  Opacity="0.45" />
                            </Border.Effect>
                        </Border>
                        <Border x:Name="Bd"
                                CornerRadius="{StaticResource ModernControlRadius}"
                                Background="{DynamicResource ModernSurfaceAltBrush}"
                                BorderBrush="{DynamicResource ModernBorderBrush}"
                                BorderThickness="1"
                                Padding="4,8,6,8"
                                SnapsToDevicePixels="True"
                                ClipToBounds="False">
                            <GridViewRowPresenter VerticalAlignment="Center"
                                                  ClipToBounds="False"
                                                  SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ModernInputHoverBrush}" />
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource ModernBorderHoverBrush}" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ModernSelectionBrush}" />
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource ModernBorderHoverBrush}" />
                            <Setter TargetName="SelGlow" Property="Opacity" Value="0.2" />
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsSelected" Value="True" />
                                <Condition Property="Selector.IsSelectionActive" Value="False" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ModernSelectionInactiveBrush}" />
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource ModernBorderBrush}" />
                            <Setter TargetName="SelGlow" Property="Opacity" Value="0.08" />
                        </MultiTrigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsSelected" Value="True" />
                                <Condition Property="IsMouseOver" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="SelGlow" Property="Opacity" Value="0.3" />
                        </MultiTrigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="{DynamicResource ModernDisabledTextBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- GroupBox -->
    <Style TargetType="{x:Type GroupBox}">
        <Setter Property="Foreground" Value="{DynamicResource ModernTextBrush}" />
        <Setter Property="Margin" Value="{StaticResource ModernSectionMargin}" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="UseLayoutRounding" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type GroupBox}">
                    <Grid Margin="1"
                          SnapsToDevicePixels="True"
                          UseLayoutRounding="True"
                          ClipToBounds="False">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Border Grid.Row="1"
                                Margin="0,8,0,0"
                                SnapsToDevicePixels="True"
                                CornerRadius="{StaticResource ModernCardRadius}"
                                Background="{DynamicResource ModernSurfaceBrush}"
                                BorderBrush="{DynamicResource ModernBorderBrush}"
                                BorderThickness="1"
                                ClipToBounds="False"
                                Padding="{StaticResource ModernCardPadding}">
                            <ContentPresenter Margin="{TemplateBinding Padding}" />
                        </Border>
                        <Border Grid.Row="0"
                                HorizontalAlignment="Left"
                                Margin="14,0,0,0"
                                Padding="6,0"
                                SnapsToDevicePixels="True"
                                Background="{DynamicResource ModernSurfaceBrush}">
                            <ContentPresenter ContentSource="Header"
                                              RecognizesAccessKey="True"
                                              TextElement.Foreground="{DynamicResource ModernTextBrush}" />
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Main navigation TabControl: fixed header row; TabPanel sits at bottom with top margin for rounded tabs. -->
    <Style x:Key="ModernTabControlStyle" TargetType="{x:Type TabControl}">
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Foreground" Value="{DynamicResource ModernTextBrush}" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="UseLayoutRounding" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type TabControl}">
                    <Grid ClipToBounds="False"
                          SnapsToDevicePixels="True"
                          UseLayoutRounding="True">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="{StaticResource ModernTabHeaderRowHeight}" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <ScrollViewer Grid.Row="0"
                                      Panel.ZIndex="2"
                                      ClipToBounds="False"
                                      HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Disabled"
                                      PanningMode="HorizontalOnly"
                                      SnapsToDevicePixels="True">
                            <Border Padding="{StaticResource ModernTabHeaderHostPadding}"
                                    ClipToBounds="False"
                                    Background="Transparent">
                                <StackPanel IsItemsHost="True"
                                            Orientation="Horizontal"
                                            VerticalAlignment="Center"
                                            ClipToBounds="False"
                                            Background="Transparent"
                                            KeyboardNavigation.TabIndex="1"
                                            SnapsToDevicePixels="True" />
                            </Border>
                        </ScrollViewer>
                        <Border Grid.Row="1"
                                Margin="0,2,0,0"
                                SnapsToDevicePixels="True"
                                BorderBrush="{DynamicResource ModernBorderBrush}"
                                BorderThickness="0,1,0,0"
                                ClipToBounds="False">
                            <ContentPresenter ContentSource="SelectedContent"
                                              Margin="0,4,0,0" />
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type TabControl}" BasedOn="{StaticResource ModernTabControlStyle}" />

    <!-- Profile Editor inner tabs: Auto header, smaller min height, same TabPanel bottom + top margin. -->
    <Style x:Key="ModernNestedTabControlStyle" TargetType="{x:Type TabControl}">
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Foreground" Value="{DynamicResource ModernTextBrush}" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="UseLayoutRounding" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type TabControl}">
                    <Grid ClipToBounds="False"
                          SnapsToDevicePixels="True"
                          UseLayoutRounding="True">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" MinHeight="{StaticResource ModernNestedTabHeaderMinHeight}" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0"
                              Panel.ZIndex="2"
                              ClipToBounds="False"
                              SnapsToDevicePixels="True"
                              UseLayoutRounding="True">
                            <TabPanel IsItemsHost="True"
                                      VerticalAlignment="Bottom"
                                      Margin="{StaticResource ModernNestedTabPanelMargin}"
                                      ClipToBounds="False"
                                      Background="Transparent"
                                      KeyboardNavigation.TabIndex="1"
                                      SnapsToDevicePixels="True" />
                        </Grid>
                        <Border Grid.Row="1"
                                SnapsToDevicePixels="True"
                                BorderBrush="{DynamicResource ModernBorderBrush}"
                                BorderThickness="0,1,0,0"
                                ClipToBounds="False">
                            <ContentPresenter ContentSource="SelectedContent"
                                              Margin="0,4,0,0" />
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type TabItem}">
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Foreground" Value="{DynamicResource ModernTextMutedBrush}" />
        <Setter Property="Background" Value="{DynamicResource ModernTabInactiveBrush}" />
        <Setter Property="Padding" Value="14,7,14,7" />
        <Setter Property="Margin" Value="{StaticResource ModernTabItemMargin}" />
        <Setter Property="MinHeight" Value="{StaticResource ModernTabItemMinHeight}" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="UseLayoutRounding" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type TabItem}">
                    <Grid Margin="{StaticResource ModernTabItemChromeMargin}"
                          SnapsToDevicePixels="True"
                          UseLayoutRounding="True"
                          ClipToBounds="False">
                        <Border x:Name="TabGlow"
                                Margin="-3"
                                CornerRadius="{StaticResource ModernTabRadius}"
                                Background="Transparent"
                                Opacity="0"
                                SnapsToDevicePixels="True">
                            <Border.Effect>
                                <DropShadowEffect Color="{DynamicResource ModernAccentGlowColor}"
                                                  BlurRadius="18"
                                                  ShadowDepth="0"
                                                  Opacity="0.9" />
                            </Border.Effect>
                        </Border>
                        <Border x:Name="Bd"
                                SnapsToDevicePixels="True"
                                CornerRadius="{StaticResource ModernTabRadius}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{DynamicResource ModernBorderBrush}"
                                BorderThickness="1"
                                ClipToBounds="False" />
                        <!-- Hover tint for inactive tabs: opacity animated for a soft ~130ms transition -->
                        <Border x:Name="HoverFade"
                                SnapsToDevicePixels="True"
                                Margin="1"
                                CornerRadius="{StaticResource ModernTabRadius}"
                                Background="{DynamicResource ModernTabInactiveHoverBrush}"
                                Opacity="0" />
                        <ContentPresenter ContentSource="Header"
                                          Margin="{TemplateBinding Padding}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          TextElement.Foreground="{TemplateBinding Foreground}"
                                          RecognizesAccessKey="True" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Foreground" Value="{DynamicResource ModernTextBrush}" />
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource ModernBorderHoverBrush}" />
                            <Setter TargetName="TabGlow" Property="Opacity" Value="0.32" />
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HoverFade"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="1" Duration="0:0:0.13" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HoverFade"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0" Duration="0:0:0.13" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ModernAccentBrush}" />
                            <Setter TargetName="HoverFade" Property="Visibility" Value="Collapsed" />
                            <Setter Property="Foreground" Value="{DynamicResource ModernOnAccentTextBrush}" />
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource ModernAccentBrush}" />
                            <Setter TargetName="Bd" Property="BorderThickness" Value="1" />
                            <Setter Property="Panel.ZIndex" Value="10" />
                            <Setter TargetName="TabGlow" Property="Opacity" Value="0.52" />
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsSelected" Value="True" />
                                <Condition Property="IsMouseOver" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="TabGlow" Property="Opacity" Value="0.65" />
                        </MultiTrigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="{DynamicResource ModernDisabledTextBrush}" />
                            <Setter TargetName="TabGlow" Property="Opacity" Value="0" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Prevent parent scroll areas from clipping rounded control chrome -->
    <Style TargetType="{x:Type ScrollViewer}">
        <Setter Property="ClipToBounds" Value="False" />
    </Style>

    <!-- Docked bottom rows with standard Buttons (Plug/Unplug, Save/Cancel, etc.). -->
    <Style x:Key="ModernBottomActionPanelStyle" TargetType="{x:Type StackPanel}">
        <Setter Property="MinHeight" Value="{StaticResource ModernBottomActionBarMinHeight}" />
        <Setter Property="Margin" Value="{StaticResource ModernBottomActionBarMargin}" />
        <Setter Property="ClipToBounds" Value="False" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

</ResourceDictionary>
