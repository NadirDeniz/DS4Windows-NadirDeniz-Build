<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit">

    <!-- Safe overrides only (do not replace ColorCanvas template — toolkit parts break at runtime). -->
    <Style TargetType="{x:Type xctk:ColorCanvas}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Foreground" Value="{DynamicResource ModernTextBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ModernBorderBrush}" />
    </Style>

</ResourceDictionary>
